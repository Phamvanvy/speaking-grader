# Giữ build context nhỏ + tránh rò rỉ secret/dữ liệu vào image.
.venv/
venv/
.git/
.gitnexus/
.pytest_cache/
__pycache__/
**/__pycache__/
*.pyc

# Secret & dữ liệu cục bộ — KHÔNG đưa vào image (TRỪ ngân hàng câu hỏi đề mẫu,
# cần cho /exam/builtin "dùng đề có sẵn").
.env
data/
!data/questions/
!data/questions/**
!data/image/
!data/image/**
outputs/
logs/
# Voice Piper TTS: mount qua volume lúc chạy (không bake vào image) → khỏi phình
# build context khi file .onnx nằm trong repo.
voices/

# Frontend React: node_modules là native theo nền (esbuild/rollup) — cài lại bằng
# npm ci trong stage frontend-build; web/dist + frontend/dist build lại, không copy
# bản cục bộ (tránh đè node_modules Windows vào image Linux → hỏng build).
frontend/node_modules/
frontend/dist/
web/dist/

# Tài liệu/khác không cần cho runtime.
docs/
tests/
*.md
