# Sao chép file này thành .env và điền API key của bạn:
#   cp .env.example .env

# Bắt buộc khi chấm điểm bằng Claude (không cần nếu chạy --no-ai)
ANTHROPIC_API_KEY=

# Model dùng để chấm. Mặc định claude-sonnet-4-6 (rẻ, hợp để tinh chỉnh prompt).
# Khi prompt ổn, đổi sang claude-opus-4-8 để benchmark chất lượng cao nhất.
TOEIC_MODEL=claude-sonnet-4-6

# Kích thước model Whisper: tiny | base | small | medium | large-v3
# base/small cho CPU; medium/large nếu có GPU.
WHISPER_MODEL=large-v3

# Thiết bị chạy Whisper: cpu | cuda
WHISPER_DEVICE=cuda


# Backend chấm điểm: anthropic (Claude, mặc định) | local (model local) |
# openrouter (model trả phí qua OpenRouter, local làm fallback).
# Dùng "local" khi phát triển để khỏi tốn tiền/đỡ cần mạng. Lưu ý điểm số sẽ
# lệch calibration so với Claude — chốt benchmark thì quay lại "anthropic".
TOEIC_BACKEND=local

# ── Backend openrouter (TOEIC_BACKEND=openrouter) ────────────────────────
# Chấm bằng model trả phí trên OpenRouter (OpenAI-compatible) để giải phóng
# CPU/GPU máy host cho ASR khi nhiều học viên chấm cùng lúc; llama.cpp local
# (cấu hình TOEIC_LOCAL_* ở trên) tự làm FALLBACK khi OpenRouter lỗi/timeout.
# ĐỔI MODEL CHẤM = ĐIỂM THAY ĐỔI → bench bằng scripts/bench_llm_scoring.py
# (capture → run) và so delta trước khi flip backend này trên production.
# LƯU Ý free model của OpenRouter limit ~50-1000 req/NGÀY → chỉ để test.
OPENROUTER_API_KEY=
# Model do bench quyết định, vd anthropic/claude-haiku-4.5
TOEIC_OPENROUTER_MODEL=
# Trần completion RIÊNG (nhiều provider reject max_tokens lớn như 180k).
TOEIC_OPENROUTER_MAX_TOKENS=8000
TOEIC_OPENROUTER_TIMEOUT=90
TOEIC_OPENROUTER_FALLBACK_LOCAL=true
# Reasoning: none (tắt — rẻ + nhanh) | low | medium | high | rỗng (model tự quyết).
TOEIC_OPENROUTER_REASONING=none
# Routing provider (nới 2 cái này mới chạy được model FREE — thường thiếu
# structured_outputs / thu thập data để train → strict sẽ 404 "No endpoints"):
# - require_parameters true = chỉ route provider hỗ trợ đủ tham số (nên giữ).
# - data_collection deny = provider không được giữ transcript học viên (nên
#   giữ cho production; "allow" chỉ khi test free với audio không nhạy cảm).
TOEIC_OPENROUTER_REQUIRE_PARAMETERS=true
TOEIC_OPENROUTER_DATA_COLLECTION=deny
# Bóc tách đề (vision) qua OpenRouter — chỉ bật khi model đã chọn CÓ vision;
# mặc định exam import vẫn đi model local như cũ.
TOEIC_OPENROUTER_VISION_EXTRACT=false

# ── Admission control (chống nghẽn khi đông học viên bấm chấm cùng lúc) ──
# Mỗi uvicorn worker chỉ chấm N bài đồng thời, còn lại xếp hàng; hàng đầy /
# chờ quá timeout → 429 + Retry-After, frontend tự retry ngầm (web/js/http.js).
# 0 = tắt (hành vi cũ: quá tải là request treo → 502). Xem src/admission.py.
TOEIC_GRADE_CONCURRENCY=4
TOEIC_GRADE_QUEUE_MAX=40
TOEIC_GRADE_QUEUE_TIMEOUT=180
TOEIC_GRADE_RETRY_AFTER=15

# Cấu hình backend local (chỉ dùng khi TOEIC_BACKEND=local).
# Ví dụ chạy Qwen3 bằng llama.cpp:
#   llama-server -hf Qwen/Qwen3-30B-A3B-GGUF --port 8080 --jinja
# llama.cpp expose API OpenAI-compatible ở /v1 và ép JSON theo schema.
TOEIC_LOCAL_BASE_URL=http://localhost:8080/v1
TOEIC_LOCAL_MODEL=Qwen3.6-35B-A3B-Q4_K_M
TOEIC_LOCAL_API_KEY=no-key
# Bật reasoning ("thinking") cho model local kiểu Qwen3. Mặc định false để
# chấm nhanh (~9s/bài thay vì ~63s khi bật, đo trên Qwen3.6-35B-A3B). Bật lại
# (true) khi cần reasoning kỹ hơn, chấp nhận chậm hơn ~6-7 lần.
TOEIC_LOCAL_ENABLE_THINKING=false

# Ngôn ngữ cho phần nhận xét (justification, suggestions, score_rationale,
# summary_feedback). Mã ngắn: vi | en | ja | ko | zh | fr | es | de, hoặc tên
# tự do (vd "Italian"). Điểm số/tiêu chí không đổi — chỉ phần giải thích.
TOEIC_FEEDBACK_LANG=vi

# Trần token LLM sinh ra cho phần chấm điểm/feedback.
TOEIC_MAX_TOKENS=50000

# Số bài chấm song song trong /grade-batch. 0 = tự (1 cho local, 4 cho cloud).
# Với local đặt 2-3 để tăng throughput: ASR (Whisper) đã serialize bằng lock GPU
# riêng (chạy 1 lúc/lần, không tranh VRAM), phần chồng lấn là tầng LLM của bài đã
# xong ASR với ASR của bài kế → batch nhanh hơn mà điểm KHÔNG đổi.
TOEIC_BATCH_CONCURRENCY=0

# Bật prefix caching phía server local (llama.cpp): gửi cache_prompt=true để tái
# dùng KV-cache của system prompt (rubric) — giống nhau giữa mọi bài cùng đề nên
# prefill chỉ tính 1 lần. Server không hỗ trợ sẽ bỏ qua. (vLLM: bật cờ server
# --enable-prefix-caching thay vì field này.) Không ảnh hưởng backend Anthropic.
TOEIC_LOCAL_PREFIX_CACHE=true

# ASR engine + model theo user mode (tách rời business mode khỏi engine):
# - practice: lane nhanh, tự leo lên mock_test khi tín hiệu kém.
# - mock_test: lane chấm chi tiết (engine tốt nhất + phoneme).
# Engine hợp lệ: faster_whisper | whisperx | insanely_fast_whisper.
# Model rỗng → fallback WHISPER_MODEL ở trên (giữ tương thích container cũ).
TOEIC_ASR_ENGINE_PRACTICE=faster_whisper
TOEIC_ASR_MODEL_PRACTICE=large-v3-turbo
TOEIC_ASR_ENGINE_MOCK_TEST=whisperx
TOEIC_ASR_MODEL_MOCK_TEST=large-v3

# Model dùng cho engine tuỳ chọn insanely_fast_whisper (transformers pipeline),
# chỉ áp dụng khi trỏ một TOEIC_ASR_ENGINE_* sang insanely_fast_whisper.
TOEIC_INSANELY_FAST_MODEL_ID=openai/whisper-large-v3

# Ngưỡng trigger auto-escalation (practice → mock_test):
# - confidence thấp
# - silence ratio cao
# - coverage thấp (Read Aloud)
TOEIC_AUTO_CONFIDENCE_THRESHOLD=0.75
TOEIC_AUTO_SILENCE_RATIO_THRESHOLD=0.35
TOEIC_AUTO_COVERAGE_THRESHOLD=0.80

# Phoneme analysis (wav2vec 2.0 — Phase 1, hybrid-ready for MFA Phase 2)
TOEIC_PHONEME_ANALYSIS_ENABLED=false
# Phải là model phoneme-CTC (output IPA), KHÔNG dùng wav2vec2-*-960h (CTC ký tự).
TOEIC_PHONEME_WAV2VEC_MODEL=facebook/wav2vec2-xlsr-53-espeak-cv-ft
# Chấm nói TIẾNG HÀN (exam=topik). Default OFF — bật SAU khi bench M2 chốt
# acoustic model; khi tắt, request exam=topik trả 400.
TOEIC_LANG_KO_ENABLED=true
# Acoustic model cho tiếng Hàn (mặc định dùng chung xlsr-espeak; bench M2 có thể
# đổi sang model Korean-phone riêng). Cache theo model_id:device — EN/KO coexist.
TOEIC_PHONEME_WAV2VEC_MODEL_KO=facebook/wav2vec2-xlsr-53-espeak-cv-ft
# Tense-fold reference tiếng Hàn: model mặc định KHÔNG có token âm căng (ㄲㄸㅃㅆㅉ)
# → fold tense→plain trong reference để không sub oan. CHỈ đặt =0 khi model_ko
# ở trên đổi sang model có token tense.
TOEIC_PHONEME_KO_TENSE_FOLD=1
TOEIC_PHONEME_DEVICE=cuda
TOEIC_PHONEME_CONFIDENCE_THRESHOLD=0.1
TOEIC_PHONEME_MIN_DURATION_SEC=0.1
# Recognizer-noise gate: ẩn các substitution bất khả thi về âm học + confidence thấp
# (wav2vec hallucinate, vd f→l, b→f) khỏi danh sách lỗi đỏ, thay vì tô đỏ oan. Lỗi VN
# thật (th-stopping ð→d, v→b, near-pair θ→s...) được bảo vệ. Ngưỡng conf tách nguyên âm
# (thấp hơn vì confidence nền thấp). Đặt _CONF=0 để TẮT gate.
TOEIC_PHONEME_RECOGNIZER_NOISE_SIM=0.2
TOEIC_PHONEME_RECOGNIZER_NOISE_CONF=0.6
TOEIC_PHONEME_RECOGNIZER_NOISE_CONF_VOWEL=0.45

# ── Các lớp leniency phoneme (code default OFF — production NÊN bật như dưới) ──
# Thiếu các flag này deploy mới sẽ chấm CHẶT hơn hẳn bản đang chạy (xem
# src/config.py để biết chi tiết từng flag; tất cả đã qua bench + learner guard).
# L1 Việt: giảm penalty nuốt phụ âm cuối kiểu L1 + trung hoà sub confidence rất thấp.
TOEIC_PHONEME_L1_ENABLED=1
# Coverage gate (Track A): từ ngắn bị "del" 100% + wav2vec im lặng + Whisper tự tin
# → cap penalty (nghi wav2vec collapse, không phải bỏ từ).
TOEIC_PHONEME_COVERAGE_GATE_ENABLED=1
# Drift cap (Track B): sub có segment NGOÀI window Whisper của từ → cap (nghi DTW
# mượn âm từ kế).
TOEIC_PHONEME_DRIFT_CAP_ENABLED=1
# Boundary refinement: sửa bleed biên từ trên DTW path (case "eyes" /zz/).
TOEIC_PHONEME_BOUNDARY_REFINE=1
# Multi-reference homograph: chọn entry CMUdict khớp acoustic (case "project").
TOEIC_PHONEME_MULTIREF=1
# S-cluster: /p t k/ sau /s/ đầu từ (speak/stay/school) là âm không bật hơi —
# recognizer nghe nhầm voicing (p→b: ok) / chỗ cấu âm (sp→st: hạ về low).
TOEIC_PHONEME_S_CLUSTER=1
# Deletion-evidence probe (telemetry-only, không đổi điểm).
TOEIC_PHONEME_DELETION_EVIDENCE=1
# Chunk audio trước wav2vec theo Whisper timestamps — fix IPA "lem" trên audio dài.
TOEIC_PHONEME_CHUNKING=hybrid
TOEIC_PHONEME_CHUNK_MAX_SEC=20

# Log prompts và phản hồi AI ra outputs/prompt_logs/ để debug/so sánh model.
# Bật bằng TOEIC_LOG_PROMPTS=true hoặc 1.
TOEIC_LOG_PROMPTS=false
# ── Lịch sử chấm bài (per-user) ──────────────────────────────────────────
# Lưu kết quả + audio gốc của mỗi lần chấm vào SQLite + đĩa, tra cứu qua tab
# "Lịch sử" trên web (user = uuid ẩn danh sinh phía trình duyệt). Tắt → các
# endpoint /history trả 404 và server không lưu gì.
TOEIC_HISTORY_ENABLED=true
# Trong Docker: mount ./data/history và trỏ 2 path vào đó (xem docker-compose.yml).
TOEIC_HISTORY_DB_PATH=data/history.db
TOEIC_HISTORY_AUDIO_DIR=data/history_audio
# Giữ tối đa N bản ghi mới nhất mỗi user (bản cũ bị xoá kèm audio). 0 = không giới hạn.
TOEIC_HISTORY_MAX_RECORDS=1000
